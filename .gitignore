# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Claude Code project memory (local AI assistant session files)
.claude/

# Environment / secrets (never commit these)
*.env
.env.*
secrets.dart
api_keys.dart

# Gradle home caches (can be hundreds of MB)
.gradle-home/
.gradle-home2/

# Dataset backup snapshots (generated by patch scripts, not source)
assets/data/*.bak.*

# Development screenshots / debug captures
screen*.png
debug_screen*.png

# IntelliJ UI designer preview files
ui.xml
ui2.xml
